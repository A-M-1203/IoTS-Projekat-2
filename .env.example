# Broker selection: mqtt | kafka
BROKER_TYPE=mqtt

# PostgreSQL
POSTGRES_USER=iotuser
POSTGRES_PASSWORD=iotpass
POSTGRES_DB=iotdb

# MQTT
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_TOPIC=iot/agriculture/readings
MQTT_QOS=1

# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=iot-agriculture-readings
KAFKA_ACKS=1

# Data Ingestion
DEVICE_COUNT=100
PUBLISH_INTERVAL_MS=100
INJECT_CRITICAL=false
CSV_PATH=/data/BIED_Smart_Agriculture_Dataset.csv

# Data Storage batching (Scenarios A & C)
BATCH_MODE=false
BATCH_SIZE=500

# Analytics
TEMP_ALERT_THRESHOLD=50.0
WINDOW_SIZE_SECONDS=10

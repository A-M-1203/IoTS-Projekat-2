BROKER_TYPE=mqtt
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_TOPIC=iot/agriculture/sensors
MQTT_SUBSCRIBE_QOS=2
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=iot-agriculture-sensors
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=iot_agriculture
POSTGRES_USER=iot
POSTGRES_PASSWORD=iot
BATCH_SIZE=20
BATCH_INTERVAL_SECONDS=5
TEMP_ALERT_THRESHOLD=20
WINDOW_SIZE_SECONDS=10
CSV_FILE_PATH=/data/BIED_Smart_Agriculture_Dataset.csv
STORAGE_BATCH_SIZE=1
BENCHMARK_MESSAGES_PER_DEVICE=1
BENCHMARK_PAYLOAD_SIZE=384
BENCHMARK_INSTANT_ALERT=false
BENCHMARK_ALERT_THRESHOLD=40
